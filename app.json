{
  "expo": {
    "name": "CampusMate",
    "slug": "campusmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "campusmate",
    "splash": {
      "backgroundColor": "#EEF6FF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cse3mad.campusmate",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CampusMate uses your location to support optional library and campus reminder features.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CampusMate can check reminders in the background when you enable location reminders."
      }
    },
    "android": {
      "package": "com.cse3mad.campusmate",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "ACCESS_BACKGROUND_LOCATION", "POST_NOTIFICATIONS"],
      "adaptiveIcon": {
        "backgroundColor": "#EEF6FF"
      }
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      "expo-task-manager"
    ],
    "extra": {
      "eas": {
        "projectId": "campusmate-local-demo"
      }
    }
  }
}
