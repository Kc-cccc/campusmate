{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["jest", "node"]
  },

  "include": ["App.tsx", "src/**/*.ts", "src/**/*.tsx"]
}
